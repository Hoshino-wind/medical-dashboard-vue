{
  "name": "medical-dashboard-vue",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.11.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview --host 0.0.0.0",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "audit:deps": "pnpm audit --registry=https://registry.npmjs.org --audit-level moderate",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check": "run-s lint type-check test:run build-only check:bundle",
    "check:ci": "run-s audit:deps check e2e"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.9.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.30.0",
    "jsdom": "^25.0.1",
    "npm-run-all2": "^7.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite": "^6.0.3",
    "vitest": "^3.2.6",
    "vue-tsc": "^2.1.10"
  }
}
