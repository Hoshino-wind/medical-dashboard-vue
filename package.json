{
  "name": "medical-dashboard-vue",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.11.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview --host 0.0.0.0",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "audit:deps": "pnpm audit --registry=https://registry.npmjs.org --audit-level moderate",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check": "run-s lint type-check test:run build-only check:bundle",
    "check:ci": "run-s audit:deps check e2e"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.10.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "typescript": "~7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
